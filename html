    {w:'find out',         vn:'phát hiện ra, tìm hiểu',                  ph:'',type:'phrasal verb',lvl:'A2',syn:'discover, learn'},
    {w:'give up',          vn:'từ bỏ',                                    ph:'',type:'phrasal verb',lvl:'A2',syn:'quit, stop trying'},
    {w:'run out of',       vn:'hết, cạn kiệt',                            ph:'',type:'phrasal verb',lvl:'B1',syn:'exhaust, deplete'},
    {w:'speed up',         vn:'tăng tốc, xảy ra nhanh hơn',              ph:'',type:'phrasal verb',lvl:'B1',syn:'accelerate'},
    {w:'die out',          vn:'diệt vong, không còn tồn tại',             ph:'',type:'phrasal verb',lvl:'B2',syn:'become extinct'},
    {w:'bounce back',      vn:'hồi phục nhanh chóng',                    ph:'',type:'phrasal verb',lvl:'C1',syn:'recover quickly'},
    {w:'stand for',        vn:'viết tắt của; đại diện cho',              ph:'',type:'phrasal verb',lvl:'B1',syn:'represent, abbreviate'},
    {w:'stem from',        vn:'xuất phát từ',                             ph:'',type:'phrasal verb',lvl:'C1',syn:'originate from'},
    {w:'call off',         vn:'hủy bỏ',                                   ph:'',type:'phrasal verb',lvl:'B2',syn:'cancel'},
    {w:'set off',          vn:'khởi hành; gây ra (chuông, bom nổ)',       ph:'',type:'phrasal verb',lvl:'B2',syn:'depart; trigger'},
  ]
};

/* ════ STATE ════ */
let totalXP=0, level=1, streak=0;
let mode='', cat='all';
let queue=[], qIdx=0, qOk=0, qNo=0, roundXP=0;
let timerID=null, timeLeft=15;
let matchSel=null, matchDone=0;
const PER=8;
const XP_MAP={quiz:10,vn2en:15,scramble:18,match:12};
const TIMER_MAP={quiz:15,vn2en:15,scramble:25,match:9999};

/* ════ HELPERS ════ */
const shuf=a=>[...a].sort(()=>Math.random()-.5);
function getPool(c){return c==='all'?Object.values(WORDS).flat():(WORDS[c]||[]);}

function showScreen(id){
  ['screen-home','screen-game','screen-end'].forEach(s=>{
    const el=document.getElementById(s);
    el.classList.remove('active'); el.style.display='none';
  });
  const t=document.getElementById(id);
  t.style.display='block';
  requestAnimationFrame(()=>t.classList.add('active'));
}

function updateHUD(){
  const pct=((totalXP%100)/100)*100;
  document.getElementById('xp-fill').style.width=pct+'%';
  document.getElementById('xp-val').textContent=(totalXP%100)+' XP';
  document.getElementById('lvl-badge').textContent='Lv.'+level;
  document.getElementById('streak-val').textContent=streak;
}
function addXP(n){totalXP+=n; level=Math.floor(totalXP/100)+1; updateHUD();}
function bumpStreak(ok){streak=ok?streak+1:0; document.getElementById('streak-val').textContent=streak;}

function particle(x,y,ok){
  const list=ok?['✨','⚡','🌿','💚']:['💨','😬'];
  for(let i=0;i<5;i++){
    const el=document.createElement('div'); el.className='ptcl';
    el.textContent=list[Math.floor(Math.random()*list.length)];
    const angle=Math.random()*Math.PI*2, dist=50+Math.random()*90;
    el.style.left=x+'px'; el.style.top=y+'px';
    el.style.setProperty('--dx',Math.cos(angle)*dist+'px');
    el.style.setProperty('--dy',Math.sin(angle)*dist+'px');
    document.body.appendChild(el); setTimeout(()=>el.remove(),950);
  }
}
function xpPop(x,y,n){
  const el=document.createElement('div'); el.className='xp-pop';
  el.textContent='+'+n+' XP'; el.style.left=x+'px'; el.style.top=y+'px';
  document.body.appendChild(el); setTimeout(()=>el.remove(),1300);
}

/* ════ HOME ════ */
document.querySelectorAll('.topic-pill').forEach(b=>{
  b.addEventListener('click',()=>{
    document.querySelectorAll('.topic-pill').forEach(x=>x.classList.remove('active'));
    b.classList.add('active'); cat=b.dataset.cat;
  });
});
document.querySelectorAll('.mode-card').forEach(c=>{
  c.addEventListener('click',()=>{mode=c.dataset.mode; startGame();});
});
document.getElementById('back-btn').addEventListener('click',()=>{stopTimer(); showScreen('screen-home');});
document.getElementById('replay-btn').addEventListener('click',startGame);
document.getElementById('home2-btn').addEventListener('click',()=>showScreen('screen-home'));

/* ════ START ════ */
function startGame(){
  const pool=getPool(cat);
  queue=shuf(pool).slice(0,mode==='match'?8:PER);
  qIdx=0; qOk=0; qNo=0; roundXP=0;
  const labels={quiz:'Trắc nghiệm',vn2en:'Việt → Anh',scramble:'Xếp chữ cái',match:'Ghép đôi'};
  document.getElementById('mode-label-txt').textContent=labels[mode]||'';
  showScreen('screen-game');
  document.getElementById('sc-ok').textContent='0 đúng';
  document.getElementById('sc-no').textContent='0 sai';

  if(mode==='match'){
    document.getElementById('card-wrap').style.display='none';
    document.getElementById('match-area').style.display='block';
    document.getElementById('prog-dots').innerHTML='';
    document.getElementById('q-cur').textContent='—'; document.getElementById('q-tot').textContent='—';
    document.getElementById('fb-bar').className='fb-bar';
    document.getElementById('next-btn').className='next-btn';
    stopTimer();
    document.getElementById('timer-num').textContent='∞';
    document.getElementById('timer-arc').style.strokeDashoffset='0';
    renderMatch();
  } else {
    document.getElementById('card-wrap').style.display='block';
    document.getElementById('match-area').style.display='none';
    buildDots(); renderQ();
  }
}

/* ════ DOTS ════ */
function buildDots(){
  const w=document.getElementById('prog-dots'); w.innerHTML='';
  queue.forEach((_,i)=>{const d=document.createElement('div');d.className='pdot'+(i===0?' cur':'');d.id='pd'+i;w.appendChild(d);});
}
function dotDone(i,ok){
  const d=document.getElementById('pd'+i); if(d) d.className='pdot '+(ok?'ok':'no');
  const n=document.getElementById('pd'+(i+1)); if(n) n.className='pdot cur';
}

/* ════ RENDER Q ════ */
function renderQ(){
  if(qIdx>=queue.length){endGame();return;}
  const it=queue[qIdx];
  document.getElementById('q-cur').textContent=qIdx+1;
  document.getElementById('q-tot').textContent=queue.length;
  document.getElementById('fb-bar').className='fb-bar';
  document.getElementById('next-btn').className='next-btn';
  document.getElementById('word-card').className='word-card';
  document.getElementById('opts-grid').style.display='none';
  document.getElementById('scr-wrap').style.display='none';
  document.getElementById('word-level').textContent=it.lvl;
  document.getElementById('word-type').textContent=it.type;
  const ph=document.getElementById('word-phonetic');
  ph.textContent=it.ph||''; ph.style.display=it.ph?'block':'none';

  if(mode==='quiz'){
    document.getElementById('word-main').textContent=it.w;
    document.getElementById('word-prompt').textContent='Chọn nghĩa tiếng Việt đúng:';
    renderQuizOpts(it);
  } else if(mode==='vn2en'){
    document.getElementById('word-main').textContent='???';
    document.getElementById('word-prompt').textContent='Nghĩa: '+it.vn;
    renderVn2EnOpts(it);
  } else if(mode==='scramble'){
    document.getElementById('word-main').textContent='???';
    document.getElementById('word-prompt').textContent='Nghĩa: '+it.vn;
    renderScramble(it);
  }
  startTimer();
}

/* ── QUIZ ── */
function renderQuizOpts(it){
  const g=document.getElementById('opts-grid'); g.style.display='grid'; g.innerHTML='';
  const pool=getPool(cat);
  const wrongs=shuf(pool.filter(x=>x.vn!==it.vn)).slice(0,3).map(x=>x.vn);
  shuf([it.vn,...wrongs]).forEach((o,i)=>{
    const b=document.createElement('button'); b.className='opt';
    b.innerHTML=`<span class="opt-key">${'ABCD'[i]}</span><span>${o}</span>`;
    b.addEventListener('click',e=>{
      if(b.disabled) return;
      const ok=o===it.vn;
      document.querySelectorAll('.opt').forEach(x=>{x.disabled=true;const t=x.querySelector('span:last-child').textContent;if(t===it.vn)x.classList.add('opt-ok');else if(x===b&&!ok)x.classList.add('opt-no');});
      handleResult(ok,it,e);
    });
    g.appendChild(b);
  });
}

/* ── VN2EN ── */
function renderVn2EnOpts(it){
  const g=document.getElementById('opts-grid'); g.style.display='grid'; g.innerHTML='';
  const pool=getPool(cat);
  const wrongs=shuf(pool.filter(x=>x.w!==it.w)).slice(0,3).map(x=>x.w);
  shuf([it.w,...wrongs]).forEach((o,i)=>{
    const b=document.createElement('button'); b.className='opt';
    b.innerHTML=`<span class="opt-key">${'ABCD'[i]}</span><span>${o}</span>`;
    b.addEventListener('click',e=>{
      if(b.disabled) return;
      const ok=o===it.w;
      document.querySelectorAll('.opt').forEach(x=>{x.disabled=true;const t=x.querySelector('span:last-child').textContent;if(t===it.w)x.classList.add('opt-ok');else if(x===b&&!ok)x.classList.add('opt-no');});
      handleResult(ok,it,e);
    });
    g.appendChild(b);
  });
}

/* ── SCRAMBLE ── */
function renderScramble(it){
  const sw=document.getElementById('scr-wrap'); sw.style.display='block';
  const ans=document.getElementById('ans-slots'); const tr=document.getElementById('tile-row');
  ans.innerHTML=''; tr.innerHTML='';
  const letters=shuf(it.w.toUpperCase().split(''));
  let chosen=[];

  it.w.split('').forEach((_,i)=>{
    const s=document.createElement('div'); s.className='slot empty'; s.dataset.si=i;
    s.addEventListener('click',()=>{
      if(!s.textContent) return;
      const ti=parseInt(s.dataset.ti);
      const idx=chosen.findIndex(c=>c.ti===ti); if(idx===-1) return;
      chosen.splice(idx,1);
      Array.from(ans.children).forEach((sl,j)=>{if(chosen[j]){sl.textContent=chosen[j].ltr;sl.dataset.ti=chosen[j].ti;sl.classList.remove('empty');}else{sl.textContent='';sl.classList.add('empty');}});
      const tile=tr.querySelector(`[data-ti="${ti}"]`); if(tile) tile.classList.remove('used');
    });
    ans.appendChild(s);
  });

  letters.forEach((ltr,i)=>{
    const t=document.createElement('div'); t.className='tile'; t.textContent=ltr; t.dataset.ti=i;
    t.addEventListener('click',()=>{
      if(t.classList.contains('used')) return;
      const si=chosen.length; if(si>=it.w.length) return;
      chosen.push({ltr,ti:i}); t.classList.add('used');
      const slot=ans.children[si]; slot.textContent=ltr; slot.classList.remove('empty'); slot.dataset.ti=i;
      if(chosen.length===it.w.length){
        const formed=chosen.map(c=>c.ltr).join('').toLowerCase();
        if(formed===it.w.toLowerCase()){
          handleResult(true,it,null);
        } else {
          Array.from(ans.children).forEach(s=>s.style.color='var(--red)');
          setTimeout(()=>{chosen.length=0;Array.from(ans.children).forEach(s=>{s.textContent='';s.className='slot empty';s.style.color='';});Array.from(tr.children).forEach(t=>t.classList.remove('used'));},650);
        }
      }
    });
    tr.appendChild(t);
  });
}

/* ── MATCH ── */
function renderMatch(){
  matchSel=null; matchDone=0;
  const items=queue;
  const wCol=document.getElementById('match-words'); const dCol=document.getElementById('match-defs');
  wCol.innerHTML=''; dCol.innerHTML='';
  const shuffled=shuf(items.map((it,i)=>({vn:it.vn,idx:i})));
  items.forEach((it,i)=>{
    const el=document.createElement('div'); el.className='match-item';
    el.textContent=it.w; el.dataset.idx=i; el.dataset.type='w';
    el.addEventListener('click',()=>matchClick(el,i,'w',items));
    wCol.appendChild(el);
  });
  shuffled.forEach(({vn,idx})=>{
    const el=document.createElement('div'); el.className='match-item';
    el.textContent=vn; el.dataset.idx=idx; el.dataset.type='d';
    el.addEventListener('click',()=>matchClick(el,idx,'d',items));
    dCol.appendChild(el);
  });
}

function matchClick(el,idx,type,items){
  if(el.classList.contains('matched')) return;
  if(!matchSel){el.classList.add('sel'); matchSel={el,idx,type}; return;}
  if(matchSel.type===type){matchSel.el.classList.remove('sel'); el.classList.add('sel'); matchSel={el,idx,type}; return;}
  const ok=matchSel.idx===idx;
  matchSel.el.classList.remove('sel');
  if(ok){
    [el,matchSel.el].forEach(e=>e.classList.add('matched'));
    matchDone++; qOk++;
    const n=XP_MAP.match; roundXP+=n; addXP(n); bumpStreak(true);
    document.getElementById('sc-ok').textContent=qOk+' đúng';
    particle(el.getBoundingClientRect().left+40,el.getBoundingClientRect().top,true);
    xpPop(el.getBoundingClientRect().left+40,el.getBoundingClientRect().top,n);
    if(matchDone===items.length) setTimeout(endGame,700);
  } else {
    [el,matchSel.el].forEach(e=>e.classList.add('wrong'));
    bumpStreak(false);
    setTimeout(()=>[el,matchSel.el].forEach(e=>e.classList.remove('wrong','sel')),700);
  }
  matchSel=null;
}

/* ════ RESULT ════ */
function handleResult(ok,it,e){
  stopTimer(); dotDone(qIdx,ok);
  if(ok) qOk++; else qNo++;
  document.getElementById('sc-ok').textContent=qOk+' đúng';
  document.getElementById('sc-no').textContent=qNo+' sai';
  const n=ok?XP_MAP[mode]:0; if(ok){roundXP+=n; addXP(n);} bumpStreak(ok);
  const card=document.getElementById('word-card');
  card.classList.add(ok?'flash-ok':'flash-no'); setTimeout(()=>card.classList.remove('flash-ok','flash-no'),600);
  const fb=document.getElementById('fb-bar');
  if(ok){
    fb.className='fb-bar ok show';
    document.getElementById('fb-icon').textContent='✅';
    document.getElementById('fb-main').textContent='Chính xác! "'+it.w+'"';
    document.getElementById('fb-vn').textContent='Nghĩa: '+it.vn;
    document.getElementById('fb-syn').textContent=it.syn?'Từ đồng nghĩa: '+it.syn:'';
    if(e){particle(e.clientX,e.clientY,true); xpPop(e.clientX,e.clientY-20,n);}
  } else {
    fb.className='fb-bar no show';
    document.getElementById('fb-icon').textContent='❌';
    document.getElementById('fb-main').textContent='Chưa đúng! "'+it.w+'" nghĩa là:';
    document.getElementById('fb-vn').textContent=it.vn;
    document.getElementById('fb-syn').textContent=it.syn?'Từ đồng nghĩa: '+it.syn:'';
    if(e) particle(e.clientX,e.clientY,false);
  }
  document.getElementById('next-btn').className='next-btn show';
}

document.getElementById('next-btn').addEventListener('click',()=>{qIdx++; qIdx>=queue.length?endGame():renderQ();});

/* ════ TIMER ════ */
function startTimer(){
  stopTimer();
  const secs=TIMER_MAP[mode];
  if(secs>=9999){document.getElementById('timer-num').textContent='∞'; document.getElementById('timer-arc').style.strokeDashoffset='0'; return;}
  timeLeft=secs;
  const arc=document.getElementById('timer-arc'); const num=document.getElementById('timer-num');
  arc.style.strokeDashoffset='0'; arc.style.stroke='#a8e063'; num.textContent=timeLeft;
  timerID=setInterval(()=>{
    timeLeft--; num.textContent=timeLeft;
    arc.style.strokeDashoffset=(125.6*(1-timeLeft/secs)).toFixed(1);
    if(timeLeft<=5) arc.style.stroke='var(--red)';
    if(timeLeft<=0){stopTimer(); handleResult(false,queue[qIdx],null); document.getElementById('fb-main').textContent='Hết giờ! "'+queue[qIdx].w+'" nghĩa là:';}
  },1000);
}
function stopTimer(){clearInterval(timerID);}

/* ════ END ════ */
function endGame(){
  stopTimer(); showScreen('screen-end');
  const total=queue.length, acc=Math.round((qOk/total)*100)||0;
  const ranks=[
    {min:90,emoji:'🏆',title:'Xuất sắc!',   sub:'Trí nhớ sắc bén — bạn thật tuyệt vời!'},
    {min:75,emoji:'🌟',title:'Giỏi lắm!',   sub:'Tiếp tục luyện để giữ phong độ nhé!'},
    {min:55,emoji:'👍',title:'Tốt đấy!',    sub:'Ôn lại những từ sai và thử lại nhé!'},
    {min:0, emoji:'💪',title:'Cố lên!',     sub:'Mỗi lần sai là một lần học — đừng bỏ cuộc!'},
  ];
  const r=ranks.find(x=>acc>=x.min);
  document.getElementById('end-emoji').textContent=r.emoji;
  document.getElementById('end-title').textContent=r.title;
  document.getElementById('end-sub').textContent=r.sub;
  document.getElementById('es-cor').textContent=qOk+'/'+total;
  document.getElementById('es-acc').textContent=acc+'%';
  document.getElementById('es-xp').textContent='+'+roundXP;
}

showScreen('screen-home');
updateHUD();
</script>
