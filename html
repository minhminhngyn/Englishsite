<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LexiViet – Luyện Từ Vựng Tiếng Anh</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0f0a; --surface:#111911; --surface2:#192119; --surface3:#1f2a1f;
  --border:rgba(180,220,120,0.08); --border2:rgba(180,220,120,0.18);
  --text:#e8f0dc; --muted:#7a9060;
  --accent:#a8e063; --accent2:#f0c040; --red:#ff6b6b; --green:#5effa0; --blue:#60c8f0;
  --glow:0 0 24px rgba(168,224,99,0.25); --glow-gold:0 0 24px rgba(240,192,64,0.3);
  --radius:18px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(168,224,99,.03)1px,transparent 1px),linear-gradient(90deg,rgba(168,224,99,.03)1px,transparent 1px);
  background-size:40px 40px;}
.bg-glow{position:fixed;width:600px;height:600px;border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;}
.bg-glow-1{background:rgba(168,224,99,.06);top:-200px;left:-100px;}
.bg-glow-2{background:rgba(240,192,64,.05);bottom:-200px;right:-100px;}

.app{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:0 20px 80px;}

/* HEADER */
header{display:flex;align-items:center;justify-content:space-between;padding:28px 0 24px;
  border-bottom:.5px solid var(--border2);margin-bottom:40px;gap:16px;flex-wrap:wrap;}
.logo{display:flex;align-items:center;gap:12px;font-family:'Fraunces',serif;font-size:24px;font-weight:900;letter-spacing:-.5px;}
.logo-mark{width:40px;height:40px;background:var(--accent);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:var(--glow);}
.logo em{font-style:normal;color:var(--accent);}
.hud{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.hud-pill{display:flex;align-items:center;gap:8px;background:var(--surface2);border:.5px solid var(--border2);border-radius:999px;padding:7px 16px;font-size:13px;font-weight:600;}
.xp-track{width:100px;height:5px;background:var(--surface3);border-radius:3px;overflow:hidden;}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:3px;transition:width .6s cubic-bezier(.34,1.56,.64,1);width:0%;}
.streak-val{color:var(--accent2);font-family:'Fraunces',serif;font-weight:700;}
.xp-val{color:var(--accent);font-family:'Fraunces',serif;font-weight:700;font-size:12px;}
.lvl-badge{background:var(--accent);color:var(--bg);border-radius:999px;padding:3px 10px;font-size:11px;font-weight:700;}

/* SCREENS */
#screen-home,#screen-game,#screen-end{display:none;}
#screen-home.active,#screen-game.active,#screen-end.active{display:block;animation:slideUp .45s cubic-bezier(.22,1,.36,1) both;}
@keyframes slideUp{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}

/* HOME */
.hero{text-align:center;margin-bottom:44px;}
.hero-tag{display:inline-block;background:rgba(168,224,99,.12);border:.5px solid rgba(168,224,99,.3);border-radius:999px;padding:5px 16px;font-size:12px;font-weight:600;color:var(--accent);letter-spacing:.08em;text-transform:uppercase;margin-bottom:18px;}
.hero h1{font-family:'Fraunces',serif;font-size:clamp(36px,7vw,62px);font-weight:900;letter-spacing:-2px;line-height:.95;margin-bottom:16px;}
.hero h1 .line2{color:var(--accent);display:block;}
.hero p{color:var(--muted);font-size:15px;line-height:1.7;max-width:440px;margin:0 auto 28px;}
.stats-row{display:flex;gap:28px;justify-content:center;}
.stat-item{text-align:center;}
.stat-n{font-family:'Fraunces',serif;font-size:28px;font-weight:900;color:var(--accent2);}
.stat-l{font-size:12px;color:var(--muted);margin-top:2px;}

.section-label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.topics-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:32px;}
.topic-pill{padding:8px 18px;border-radius:999px;border:.5px solid var(--border2);background:var(--surface);color:var(--muted);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;}
.topic-pill:hover{color:var(--text);border-color:rgba(168,224,99,.4);}
.topic-pill.active{background:var(--accent);color:var(--bg);border-color:var(--accent);box-shadow:var(--glow);}

.modes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;}
.mode-card{background:var(--surface);border:.5px solid var(--border2);border-radius:var(--radius);padding:26px 22px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden;}
.mode-card::before{content:'';position:absolute;inset:0;border-radius:var(--radius);opacity:0;transition:opacity .3s;}
.mode-card.cg::before{background:radial-gradient(circle at top left,rgba(168,224,99,.12),transparent 65%);}
.mode-card.co::before{background:radial-gradient(circle at top left,rgba(240,192,64,.12),transparent 65%);}
.mode-card.cb::before{background:radial-gradient(circle at top left,rgba(96,200,240,.12),transparent 65%);}
.mode-card.cr::before{background:radial-gradient(circle at top left,rgba(255,107,107,.12),transparent 65%);}
.mode-card:hover{transform:translateY(-5px);}
.mode-card:hover::before{opacity:1;}
.mode-card:hover.cg{border-color:rgba(168,224,99,.4);box-shadow:var(--glow);}
.mode-card:hover.co{border-color:rgba(240,192,64,.4);box-shadow:var(--glow-gold);}
.mode-icon{font-size:30px;margin-bottom:14px;display:block;}
.mode-badge{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;}
.cg .mode-badge{color:var(--accent);} .co .mode-badge{color:var(--accent2);} .cb .mode-badge{color:var(--blue);} .cr .mode-badge{color:var(--red);}
.mode-name{font-family:'Fraunces',serif;font-size:19px;font-weight:700;margin-bottom:8px;}
.mode-desc{font-size:13px;color:var(--muted);line-height:1.5;}
.mode-xp{margin-top:14px;font-size:11px;font-weight:700;}
.cg .mode-xp{color:var(--accent);} .co .mode-xp{color:var(--accent2);} .cb .mode-xp{color:var(--blue);} .cr .mode-xp{color:var(--red);}

/* GAME */
.game-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;gap:12px;}
.back-btn{background:var(--surface);border:.5px solid var(--border2);border-radius:12px;padding:9px 18px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;}
.back-btn:hover{color:var(--text);}
.mode-label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.game-meta{display:flex;align-items:center;gap:14px;}
.q-count{font-family:'Fraunces',serif;font-size:14px;color:var(--muted);}
.q-count span{color:var(--text);font-weight:700;}

.timer-wrap{position:relative;width:50px;height:50px;}
.timer-wrap svg{transform:rotate(-90deg);}
.timer-arc{transition:stroke-dashoffset 1s linear;}
.timer-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:14px;font-weight:700;}

.prog-dots{display:flex;gap:5px;justify-content:center;margin-bottom:18px;}
.pdot{height:4px;width:20px;border-radius:2px;background:var(--surface3);transition:all .3s;}
.pdot.ok{background:var(--green);} .pdot.no{background:var(--red);width:8px;} .pdot.cur{background:var(--accent);}

.score-mini{display:flex;gap:14px;margin-bottom:18px;}
.s-pill{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:var(--muted);}
.s-dot{width:8px;height:8px;border-radius:50%;}
.s-green{background:var(--green);} .s-red{background:var(--red);}

.word-card{background:var(--surface);border:.5px solid var(--border2);border-radius:24px;padding:36px 32px 28px;text-align:center;margin-bottom:16px;transition:border-color .3s,box-shadow .3s;position:relative;overflow:hidden;}
.word-card::before{content:'';position:absolute;top:-40px;left:50%;transform:translateX(-50%);width:280px;height:180px;background:radial-gradient(circle,rgba(168,224,99,.06),transparent 70%);pointer-events:none;}
.word-card.flash-ok{border-color:var(--green);box-shadow:0 0 24px rgba(94,255,160,.3);}
.word-card.flash-no{border-color:var(--red);box-shadow:0 0 24px rgba(255,107,107,.3);}
.word-level{display:inline-flex;align-items:center;background:rgba(168,224,99,.1);border:.5px solid rgba(168,224,99,.25);border-radius:999px;padding:3px 12px;font-size:11px;font-weight:700;color:var(--accent);letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px;}
.word-type{font-size:12px;color:var(--muted);font-weight:600;font-style:italic;margin-bottom:6px;}
.word-main{font-family:'Fraunces',serif;font-size:clamp(32px,6vw,52px);font-weight:900;letter-spacing:-1.5px;line-height:1;margin-bottom:8px;}
.word-phonetic{font-size:14px;color:var(--blue);margin-bottom:14px;font-weight:500;}
.word-prompt{font-size:15px;color:var(--muted);line-height:1.6;max-width:500px;margin:0 auto;}

.opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;}
.opt{background:var(--surface);border:.5px solid var(--border2);border-radius:16px;padding:16px 18px;display:flex;align-items:flex-start;gap:12px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;color:var(--text);cursor:pointer;text-align:left;line-height:1.4;transition:all .18s;}
.opt-key{width:28px;height:28px;border-radius:8px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--muted);flex-shrink:0;transition:all .18s;font-family:'Fraunces',serif;}
.opt:hover:not(:disabled){border-color:rgba(168,224,99,.4);background:rgba(168,224,99,.05);}
.opt:hover:not(:disabled) .opt-key{background:rgba(168,224,99,.2);color:var(--accent);}
.opt.opt-ok{border-color:var(--green);background:rgba(94,255,160,.07);color:var(--green);}
.opt.opt-ok .opt-key{background:var(--green);color:var(--bg);border-color:var(--green);}
.opt.opt-no{border-color:var(--red);background:rgba(255,107,107,.07);color:var(--red);}
.opt.opt-no .opt-key{background:var(--red);color:var(--bg);border-color:var(--red);}
.opt:disabled{cursor:default;}

.scr-wrap{margin-bottom:16px;}
.ans-slots{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:16px;}
.slot{width:42px;height:50px;border-bottom:2.5px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:20px;font-weight:700;color:var(--accent);cursor:pointer;transition:all .15s;}
.slot.empty{opacity:.3;}
.slot:not(.empty):hover{border-color:var(--red);color:var(--red);}
.tile-row{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.tile{width:42px;height:50px;background:var(--surface2);border:.5px solid var(--border2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:20px;font-weight:700;cursor:pointer;transition:all .15s;user-select:none;}
.tile:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-3px);}
.tile.used{opacity:.2;pointer-events:none;}

.match-wrap{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.match-col-head{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
.match-items{display:flex;flex-direction:column;gap:8px;}
.match-item{background:var(--surface);border:.5px solid var(--border2);border-radius:14px;padding:12px 16px;font-size:13px;font-weight:600;cursor:pointer;text-align:center;transition:all .18s;user-select:none;line-height:1.4;}
.match-item:hover{border-color:rgba(168,224,99,.4);color:var(--accent);}
.match-item.sel{background:rgba(168,224,99,.12);border-color:var(--accent);color:var(--accent);}
.match-item.matched{background:rgba(94,255,160,.08);border-color:var(--green);color:var(--green);pointer-events:none;opacity:.7;}
.match-item.wrong{background:rgba(255,107,107,.08);border-color:var(--red);color:var(--red);}

.fb-bar{border-radius:14px;padding:14px 18px;display:none;align-items:flex-start;gap:12px;font-size:14px;font-weight:600;line-height:1.5;margin-bottom:14px;}
.fb-bar.show{display:flex;}
.fb-bar.ok{background:rgba(94,255,160,.08);border:.5px solid rgba(94,255,160,.4);color:var(--green);}
.fb-bar.no{background:rgba(255,107,107,.08);border:.5px solid rgba(255,107,107,.4);color:var(--red);}
.fb-icon{font-size:20px;flex-shrink:0;}
.fb-body{flex:1;}
.fb-main{margin-bottom:3px;}
.fb-vn{font-size:12px;opacity:.85;font-weight:400;}
.fb-syn{font-size:11px;color:var(--blue);margin-top:4px;font-weight:500;}

.next-btn{width:100%;display:none;background:var(--surface2);border:.5px solid var(--border2);border-radius:14px;padding:16px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;color:var(--text);cursor:pointer;transition:all .2s;}
.next-btn.show{display:block;}
.next-btn:hover{background:var(--surface3);border-color:rgba(255,255,255,.15);}

/* END */
.end-card{background:var(--surface);border:.5px solid var(--border2);border-radius:28px;padding:48px 40px;text-align:center;position:relative;overflow:hidden;}
.end-card::before{content:'';position:absolute;top:-80px;left:50%;transform:translateX(-50%);width:320px;height:320px;background:radial-gradient(circle,rgba(168,224,99,.1),transparent 70%);pointer-events:none;}
.end-emoji{font-size:64px;margin-bottom:10px;}
.end-title{font-family:'Fraunces',serif;font-size:34px;font-weight:900;letter-spacing:-1px;margin-bottom:8px;}
.end-sub{color:var(--muted);font-size:15px;margin-bottom:36px;}
.end-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:36px;}
.end-stat{background:var(--surface2);border-radius:16px;padding:20px 14px;}
.end-stat-n{font-family:'Fraunces',serif;font-size:30px;font-weight:900;margin-bottom:4px;}
.end-stat-l{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;}
.end-actions{display:flex;gap:12px;justify-content:center;}
.btn-main{background:var(--accent);border:none;border-radius:14px;padding:14px 32px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;color:var(--bg);cursor:pointer;box-shadow:var(--glow);transition:all .2s;}
.btn-main:hover{transform:translateY(-2px);}
.btn-ghost{background:transparent;border:.5px solid var(--border2);border-radius:14px;padding:14px 32px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:700;color:var(--muted);cursor:pointer;transition:all .2s;}
.btn-ghost:hover{color:var(--text);border-color:rgba(255,255,255,.2);}

/* particles */
.ptcl{position:fixed;pointer-events:none;font-size:18px;z-index:999;animation:ptclFly .9s ease forwards;}
@keyframes ptclFly{from{opacity:1;transform:translate(0,0) scale(1);}to{opacity:0;transform:translate(var(--dx),var(--dy)) scale(.2);}}
.xp-pop{position:fixed;pointer-events:none;font-family:'Fraunces',serif;font-size:14px;font-weight:700;color:var(--accent);z-index:999;animation:xpFloat 1.2s ease forwards;}
@keyframes xpFloat{from{opacity:1;transform:translateY(0) scale(1);}to{opacity:0;transform:translateY(-70px) scale(.8);}}

@media(max-width:580px){
  .opts-grid{grid-template-columns:1fr;}
  .match-wrap{grid-template-columns:1fr;}
  .end-stats{grid-template-columns:1fr;}
  .end-actions{flex-direction:column;}
  .modes-grid{grid-template-columns:1fr 1fr;}
}
@media(max-width:400px){.modes-grid{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>

<div class="app">
<header>
  <div class="logo"><div class="logo-mark">🌿</div>Lexi<em>Viet</em></div>
  <div class="hud">
    <div class="hud-pill">
      <span class="lvl-badge" id="lvl-badge">Lv.1</span>
      <div class="xp-track"><div class="xp-fill" id="xp-fill"></div></div>
      <span class="xp-val" id="xp-val">0 XP</span>
    </div>
    <div class="hud-pill">🔥 <span class="streak-val" id="streak-val">0</span></div>
  </div>
</header>

<!-- HOME -->
<div id="screen-home">
  <div class="hero">
    <div class="hero-tag">🇻🇳 Dành cho học sinh Việt Nam</div>
    <h1>Luyện từ vựng<span class="line2">thông minh hơn.</span></h1>
    <p>Từ vựng tiếng Anh trọng tâm cho kỳ thi THPT & ĐGNL 2026 — biên soạn bởi Cô Vũ Thị Mai Phương.</p>
    <div class="stats-row">
      <div class="stat-item"><div class="stat-n">100+</div><div class="stat-l">Từ vựng</div></div>
      <div class="stat-item"><div class="stat-n">4</div><div class="stat-l">Chế độ chơi</div></div>
      <div class="stat-item"><div class="stat-n">C1–C2</div><div class="stat-l">Cấp độ</div></div>
    </div>
  </div>

  <div class="section-label">📚 Chọn chủ đề</div>
  <div class="topics-row" id="topics-row">
    <button class="topic-pill active" data-cat="all">Tất cả</button>
    <button class="topic-pill" data-cat="sgk">SGK mở rộng</button>
    <button class="topic-pill" data-cat="advanced">Từ nâng cao C1-C2</button>
    <button class="topic-pill" data-cat="collocation">Collocation</button>
    <button class="topic-pill" data-cat="phrasal">Phrasal Verbs</button>
  </div>

  <div class="section-label" style="margin-top:8px">🎮 Chọn chế độ chơi</div>
  <div class="modes-grid">
    <div class="mode-card cg" data-mode="quiz">
      <span class="mode-icon">⚡</span>
      <div class="mode-badge">Cổ điển</div>
      <div class="mode-name">Trắc nghiệm</div>
      <div class="mode-desc">Xem từ tiếng Anh, chọn nghĩa tiếng Việt đúng trong 4 đáp án.</div>
      <div class="mode-xp">+10 XP / câu đúng</div>
    </div>
    <div class="mode-card co" data-mode="vn2en">
      <span class="mode-icon">🔄</span>
      <div class="mode-badge">Dịch ngược</div>
      <div class="mode-name">Việt → Anh</div>
      <div class="mode-desc">Đọc nghĩa tiếng Việt, chọn từ tiếng Anh tương ứng — khó hơn!</div>
      <div class="mode-xp">+15 XP / câu đúng</div>
    </div>
    <div class="mode-card cb" data-mode="scramble">
      <span class="mode-icon">🔀</span>
      <div class="mode-badge">Ghép chữ</div>
      <div class="mode-name">Xếp chữ cái</div>
      <div class="mode-desc">Đọc nghĩa tiếng Việt, sắp xếp các chữ cái thành từ đúng.</div>
      <div class="mode-xp">+18 XP / câu đúng</div>
    </div>
    <div class="mode-card cr" data-mode="match">
      <span class="mode-icon">🎯</span>
      <div class="mode-badge">Nối từ</div>
      <div class="mode-name">Ghép đôi</div>
      <div class="mode-desc">Nối từ tiếng Anh với nghĩa tiếng Việt. Không được sai!</div>
      <div class="mode-xp">+12 XP / cặp đúng</div>
    </div>
  </div>
</div>

<!-- GAME -->
<div id="screen-game">
  <div class="game-bar">
    <button class="back-btn" id="back-btn">← Quay lại</button>
    <span class="mode-label" id="mode-label-txt">Trắc nghiệm</span>
    <div class="game-meta">
      <span class="q-count"><span id="q-cur">1</span> / <span id="q-tot">8</span></span>
      <div class="timer-wrap">
        <svg width="50" height="50" viewBox="0 0 50 50">
          <circle cx="25" cy="25" r="20" fill="none" stroke="#192119" stroke-width="4"/>
          <circle class="timer-arc" id="timer-arc" cx="25" cy="25" r="20"
            fill="none" stroke="#a8e063" stroke-width="4"
            stroke-linecap="round" stroke-dasharray="125.6" stroke-dashoffset="0"/>
        </svg>
        <div class="timer-num" id="timer-num">15</div>
      </div>
    </div>
  </div>

  <div class="score-mini">
    <div class="s-pill"><span class="s-dot s-green"></span><span id="sc-ok">0 đúng</span></div>
